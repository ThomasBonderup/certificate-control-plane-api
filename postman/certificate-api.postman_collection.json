  "item": [
    {
      "name": "Get Demo Read Token",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "password",
              "type": "text"
            },
            {
              "key": "client_id",
              "value": "{{demoReadClientId}}",
              "type": "text"
            },
            {
              "key": "client_secret",
              "value": "{{demoReadClientSecret}}",
              "type": "text"
            },
            {
              "key": "username",
              "value": "{{demoReadUsername}}",
              "type": "text"
            },
            {
              "key": "password",
              "value": "{{demoReadPassword}}",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{keycloakBaseUrl}}/realms/{{realm}}/protocol/openid-connect/token",
          "host": [
            "{{keycloakBaseUrl}}"
          ],
          "path": [
            "realms",
            "{{realm}}",
            "protocol",
            "openid-connect",
            "token"
          ]
        },
        "description": "Gets a demo-tenant read-only Keycloak access token and stores `accessToken`, `accessTokenScope`, `accessTokenSubject`, and `accessTokenTenantId`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function decodeJwtPayload(token) {",
              "  var encodedPayload = token.split('.')[1];",
              "  var base64 = encodedPayload.replace(/-/g, '+').replace(/_/g, '/');",
              "  var padded = base64.padEnd(base64.length + ((4 - base64.length % 4) % 4), '=');",
              "  return JSON.parse(atob(padded));",
              "}",
              "",
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var body = pm.response.json();",
              "pm.test(\"access token is present\", function () {",
              "  pm.expect(body.access_token).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "if (body && body.access_token) {",
              "  pm.collectionVariables.set(\"accessToken\", body.access_token);",
              "  var payload = decodeJwtPayload(body.access_token);",
              "  pm.collectionVariables.set(\"accessTokenScope\", payload.scope || \"\");",
              "  pm.collectionVariables.set(\"accessTokenSubject\", payload.sub || \"\");",
              "  pm.collectionVariables.set(\"accessTokenTenantId\", payload.tenantId || \"\");",
              "  pm.collectionVariables.set(\"activeTokenProfile\", \"read\");",
              "  console.log(\"JWT subject:\", payload.sub || \"<missing>\");",
              "  console.log(\"JWT scopes:\", payload.scope || \"<missing>\");",
              "  console.log(\"JWT tenantId:\", payload.tenantId || \"<missing>\");",
              "}"
            ]
          }
        }
      ]
    },
