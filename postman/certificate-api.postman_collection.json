    {
      "name": "Authorization Demo - Read Token Cannot Create Certificate",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantId\": \"demo-tenant\",\n  \"name\": \"Read Token Should Fail\",\n  \"commonName\": \"read-denied.example.com\",\n  \"issuer\": \"Combotto CA\",\n  \"serialNumber\": \"read-denied-001\",\n  \"sha256Fingerprint\": \"10:11:12:13\",\n  \"notBefore\": \"2026-04-01T00:00:00Z\",\n  \"notAfter\": \"2026-07-01T00:00:00Z\",\n  \"status\": \"ACTIVE\",\n  \"renewalStatus\": \"NOT_STATUS\",\n  \"owner\": \"postman\",\n  \"notes\": \"Should fail with read token\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/certificates",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "certificates"
          ]
        },
        "description": "Authorization demo. Run `Get Read Token` first. This request should return 403 Forbidden because the token only has `controlplane.read`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 403\", function () {",
              "  pm.response.to.have.status(403);",
              "});",
              "",
              "console.log(\"Active token profile:\", pm.collectionVariables.get(\"activeTokenProfile\") || \"<unknown>\");",
              "console.log(\"Access token scopes:\", pm.collectionVariables.get(\"accessTokenScope\") || \"<unknown>\");"
            ]
          }
        }
      ]
    },
