      "key": "activeTokenProfile",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "accessTokenScope",
      "value": ""
    },
    {
      "key": "accessTokenSubject",
      "value": ""
    },
    {
      "key": "accessTokenTenantId",
      "value": ""
    },
    {
      "key": "certificateId",
      "value": ""
