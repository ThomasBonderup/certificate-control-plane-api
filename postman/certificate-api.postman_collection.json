    {
      "name": "Create Certificate",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantId\": \"demo-tenant\",\n  \"name\": \"Broker TLS Certificate\",\n  \"commonName\": \"mqtt.example.com\",\n  \"issuer\": \"Let's Encrypt\",\n  \"serialNumber\": \"123456789\",\n  \"sha256Fingerprint\": \"AB:CD:EF:12:34\",\n  \"notBefore\": \"2026-04-01T00:00:00Z\",\n  \"notAfter\": \"2026-07-01T00:00:00Z\",\n  \"status\": \"ACTIVE\",\n  \"renewalStatus\": \"NOT_STATUS\",\n  \"owner\": \"thomas\",\n  \"notes\": \"Primary broker certificate\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/certificates",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "certificates"
          ]
        },
        "description": "Creates a certificate and stores the returned id into `certificateId`. The request body tenantId must match the JWT `tenantId` claim, and the API persists the JWT tenant boundary."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "var body = pm.response.json();",
              "if (body && body.id) {",
              "  pm.collectionVariables.set(\"certificateId\", body.id);",
              "}"
            ]
          }
        }
      ]
    },
