# Local Docker Compose overrides
# Copy to .env if you want to customize ports or credentials.

POSTGRES_DB=combotto_control_plane
POSTGRES_USER=devuser
POSTGRES_PASSWORD=changeme

POSTGRES_HOST_PORT=5432
KAFKA_HOST_PORT=9092
KAFKA_UI_HOST_PORT=8081
CONTROL_PLANE_PORT=8080
KEYCLOAK_HOST_PORT=9000

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin

KEYCLOAK_DEMO_READ_CLIENT_ID=control-plane-demo-read-cli
KEYCLOAK_DEMO_READ_CLIENT_SECRET=local-dev-demo-read-secret
KEYCLOAK_DEMO_WRITE_CLIENT_ID=control-plane-demo-write-cli
KEYCLOAK_DEMO_WRITE_CLIENT_SECRET=local-dev-demo-write-secret

KEYCLOAK_DEMO_READ_USERNAME=local-demo-reader
KEYCLOAK_DEMO_READ_PASSWORD=local-demo-reader-password
KEYCLOAK_DEMO_READ_EMAIL=local-demo-reader@example.com
KEYCLOAK_DEMO_WRITE_USERNAME=local-demo-writer
KEYCLOAK_DEMO_WRITE_PASSWORD=local-demo-writer-password
KEYCLOAK_DEMO_WRITE_EMAIL=local-demo-writer@example.com
KEYCLOAK_DEMO_TENANT_ID=demo-tenant

KEYCLOAK_OTHER_READ_USERNAME=local-other-reader
KEYCLOAK_OTHER_READ_PASSWORD=local-other-reader-password
KEYCLOAK_OTHER_READ_EMAIL=local-other-reader@example.com
KEYCLOAK_OTHER_WRITE_USERNAME=local-other-writer
KEYCLOAK_OTHER_WRITE_PASSWORD=local-other-writer-password
KEYCLOAK_OTHER_WRITE_EMAIL=local-other-writer@example.com
KEYCLOAK_OTHER_TENANT_ID=other-tenant