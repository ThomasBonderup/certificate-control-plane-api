# Local Docker Compose overrides
# Copy to .env if you want to customize ports or credentials.

POSTGRES_DB=combotto_control_plane
POSTGRES_USER=devuser
POSTGRES_PASSWORD=changeme

POSTGRES_HOST_PORT=5432
KAFKA_HOST_PORT=9092
KAFKA_UI_HOST_PORT=8081
CONTROL_PLANE_PORT=8080
KEYCLOAK_HOST_PORT=9000

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin

KEYCLOAK_READ_CLIENT_ID=control-plane-read-cli
KEYCLOAK_READ_CLIENT_SECRET=local-dev-read-secret
KEYCLOAK_READ_USERNAME=local-reader
KEYCLOAK_READ_PASSWORD=local-reader-password
KEYCLOAK_READ_EMAIL=local-reader@example.com

KEYCLOAK_WRITE_CLIENT_ID=control-plane-write-cli
KEYCLOAK_WRITE_CLIENT_SECRET=local-dev-write-secret
KEYCLOAK_WRITE_USERNAME=local-writer
KEYCLOAK_WRITE_PASSWORD=local-writer-password
KEYCLOAK_WRITE_EMAIL=local-writer@example.com
