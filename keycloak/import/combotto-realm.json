{
  "realm": "combotto",
  "enabled": true,
  "displayName": "Combotto Local Dev",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "control-plane-api-cli",
      "name": "Control Plane CLI",
      "description": "Local development client for manual token generation",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEYCLOAK_DEV_CLIENT_SECRET}",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "users": [
    {
      "username": "local-dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Local",
      "lastName": "Developer",
      "email": "local-dev@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_DEV_USER_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-combotto"
      ]
    }
  ]
}
