{
  "realm": "combotto",
  "enabled": true,
  "displayName": "Combotto Local Dev",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "clientScopes": [
    {
      "name": "controlplane.read",
      "description": "Read access to control plane APIs",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    },
    {
      "name": "controlplane.write",
      "description": "Write access to control plane APIs",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    },
    {
      "name": "tenant-context",
      "description": "Adds tenant context to access tokens",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "tenantId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenantId",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "${KEYCLOAK_DEMO_READ_CLIENT_ID}",
      "name": "Control Plane Read CLI",
      "description": "Local development client for read-only token generation",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEYCLOAK_DEMO_READ_CLIENT_SECRET}",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "controlplane.read",
        "tenant-context"
      ],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String"
          }
        }
      ],
      "redirectUris": [],
      "webOrigins": []
    },
    {
      "clientId": "${KEYCLOAK_DEMO_WRITE_CLIENT_ID}",
      "name": "Control Plane Write CLI",
      "description": "Local development client for write-only token generation",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEYCLOAK_DEMO_WRITE_CLIENT_SECRET}",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "controlplane.write",
        "tenant-context"
      ],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String"
          }
        }
      ],
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Administrative access for sensitive control plane operations"
      }
    ]
  },
  "users": [
    {
      "username": "${KEYCLOAK_DEMO_READ_USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Reader",
      "email": "${KEYCLOAK_DEMO_READ_EMAIL}",
      "attributes": {
        "tenant_id": [
          "${KEYCLOAK_DEMO_TENANT_ID}"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_DEMO_READ_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-combotto"
      ]
    },
    {
      "username": "${KEYCLOAK_DEMO_WRITE_USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Writer",
      "email": "${KEYCLOAK_DEMO_WRITE_EMAIL}",
      "attributes": {
        "tenant_id": [
          "${KEYCLOAK_DEMO_TENANT_ID}"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_DEMO_WRITE_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-combotto",
        "ADMIN"
      ]
    },
    {
      "username": "${KEYCLOAK_DEMO_WRITE_NO_ADMIN_USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Writer No Admin",
      "email": "${KEYCLOAK_DEMO_WRITE_NO_ADMIN_EMAIL}",
      "attributes": {
        "tenant_id": [
          "${KEYCLOAK_DEMO_TENANT_ID}"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_DEMO_WRITE_NO_ADMIN_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-combotto"
      ]
    },
    {
      "username": "${KEYCLOAK_OTHER_READ_USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Other",
      "lastName": "Reader",
      "email": "${KEYCLOAK_OTHER_READ_EMAIL}",
      "attributes": {
        "tenant_id": [
          "${KEYCLOAK_OTHER_TENANT_ID}"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_OTHER_READ_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-combotto"
      ]
    },
    {
      "username": "${KEYCLOAK_OTHER_WRITE_USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Other",
      "lastName": "Writer",
      "email": "${KEYCLOAK_OTHER_WRITE_EMAIL}",
      "attributes": {
        "tenant_id": [
          "${KEYCLOAK_OTHER_TENANT_ID}"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_OTHER_WRITE_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-combotto",
        "ADMIN"
      ]
    }
  ]
}
